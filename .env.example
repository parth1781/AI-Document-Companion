# ============================================================
# LEARNING HUB - Environment Variables
# Copy this file and fill in your actual values.
# Never commit the real .env file to Git.
# ============================================================

# --- Server ---
PORT=5000

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- App Settings ---
MAX_FILE_SIZE=10485760
KILL_SWITCH_ACTIVE=false

# --- Auth ---
JWT_SECRET=change_this_to_a_random_64_char_string

# --- SMTP Email (for OTP Password Reset) ---
# Gmail: Enable 2FA then generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Learning Hub <your_email@gmail.com>

# --- Vercel (set automatically by Vercel, do not set manually) ---
# VERCEL=1

# --- CORS (optional: your custom domain if you have one) ---
# FRONTEND_URL=https://your-custom-domain.com
